{
  "expo": {
    "name": "Navigator",
    "slug": "robot-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",

    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "assetBundlePatterns": [
      "**/*"
    ],

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },

    "android": {
      "package": "com.jakep623.robotapp",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD31AhJNrjapXsUeT4nRKWBA_gRUrC16g0"
        }
      }
    },

    "plugins": [
      "expo-dev-client",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Navigator to use your phone location for weather scheduling."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1f5f9f"
        }
      ],
      "expo-maps"
    ],

    "extra": {
      "eas": {
        "projectId": "14e1cd26-55ee-4e6c-b06a-2497e95959eb"
      }
    }
  }
}
